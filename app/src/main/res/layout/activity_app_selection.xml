<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true">

    <!-- ── AppBar ─────────────────────────────────────────────── -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_primary"
        app:elevation="0dp"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/text_primary"
            app:title="@string/app_selection_title"
            app:titleTextAppearance="@style/TextAppearance.ScrollGuard.Title"
            app:titleTextColor="@color/text_primary">

            <!-- Selected count label pinned to end -->
            <TextView
                android:id="@+id/tv_selected_count"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_gravity="end"
                android:layout_marginEnd="@dimen/space_16"
                android:textSize="13sp"
                android:textColor="@color/color_primary"
                android:fontFamily="@font/inter" />
        </com.google.android.material.appbar.MaterialToolbar>

        <!-- Search bar (inside AppBar, below toolbar) -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="48dp"
            android:layout_marginHorizontal="@dimen/screen_padding_h"
            android:layout_marginBottom="@dimen/space_8"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:background="@drawable/bg_search_bar"
            android:paddingHorizontal="14dp">

            <ImageView
                android:layout_width="@dimen/icon_sm"
                android:layout_height="@dimen/icon_sm"
                android:src="@drawable/ic_search"
                app:tint="@color/text_hint" />

            <EditText
                android:id="@+id/et_search"
                android:layout_width="0dp"
                android:layout_height="match_parent"
                android:layout_weight="1"
                android:layout_marginStart="@dimen/space_8"
                android:background="@null"
                android:hint="@string/search_hint"
                android:textColorHint="@color/text_hint"
                android:textColor="@color/text_primary"
                android:fontFamily="@font/inter"
                android:textSize="15sp"
                android:inputType="text"
                android:imeOptions="actionSearch"
                android:maxLines="1" />
        </LinearLayout>
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ── App list ───────────────────────────────────────────── -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rv_apps"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingHorizontal="@dimen/screen_padding_h"
        android:paddingBottom="80dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior" />

    <!-- ── Confirm button — sticky bottom ─────────────────────── -->
    <Button
        android:id="@+id/btn_confirm"
        style="@style/Widget.ScrollGuard.Button.Primary"
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:layout_gravity="bottom"
        android:layout_marginHorizontal="@dimen/screen_padding_h"
        android:layout_marginBottom="@dimen/space_16"
        android:text="@string/btn_confirm_selection" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
