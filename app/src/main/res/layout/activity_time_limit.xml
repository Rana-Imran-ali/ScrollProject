<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_primary"
    android:fitsSystemWindows="true">

    <!-- ── AppBar ─────────────────────────────────────────────── -->
    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_primary"
        app:elevation="0dp"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/text_primary"
            app:title="@string/time_limit_title"
            app:titleTextAppearance="@style/TextAppearance.ScrollGuard.Title"
            app:titleTextColor="@color/text_primary" />
    </com.google.android.material.appbar.AppBarLayout>

    <!-- ── Two-panel body ────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="horizontal"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <!-- Left: app list -->
        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_apps"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.42"
            android:paddingVertical="@dimen/space_8"
            android:clipToPadding="false" />

        <!-- Divider -->
        <View
            android:layout_width="1dp"
            android:layout_height="match_parent"
            android:background="@color/divider" />

        <!-- Right: chip picker + save -->
        <androidx.core.widget.NestedScrollView
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="0.58">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:gravity="center_horizontal"
                android:padding="@dimen/space_24">

                <!-- Selected app icon -->
                <FrameLayout
                    android:layout_width="64dp"
                    android:layout_height="64dp"
                    android:layout_marginBottom="@dimen/space_8"
                    android:background="@drawable/bg_icon_badge">

                    <ImageView
                        android:id="@+id/iv_selected_icon"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:padding="4dp"
                        android:contentDescription="App icon" />
                </FrameLayout>

                <!-- Selected app name -->
                <TextView
                    android:id="@+id/tv_selected_name"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_24"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary"
                    android:fontFamily="@font/inter"
                    android:gravity="center"
                    android:maxLines="1"
                    android:ellipsize="end"
                    tools:text="Instagram" />

                <!-- Section label -->
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_12"
                    android:text="Daily Limit"
                    android:textSize="12sp"
                    android:letterSpacing="0.08"
                    android:textAllCaps="true"
                    android:textColor="@color/text_hint"
                    android:fontFamily="@font/inter" />

                <!-- ── Chip Group (replaces NumberPicker) ── -->
                <com.google.android.material.chip.ChipGroup
                    android:id="@+id/chip_group_limits"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_20"
                    app:singleSelection="true"
                    app:selectionRequired="true"
                    app:chipSpacingHorizontal="@dimen/space_8"
                    app:chipSpacingVertical="@dimen/space_8">

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_15m"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:text="15 min"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/inter"
                        app:chipBackgroundColor="@color/bg_card_elevated"
                        app:chipStrokeColor="@color/border"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_30m"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:text="30 min"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/inter"
                        app:chipBackgroundColor="@color/bg_card_elevated"
                        app:chipStrokeColor="@color/border"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_45m"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:text="45 min"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/inter"
                        app:chipBackgroundColor="@color/bg_card_elevated"
                        app:chipStrokeColor="@color/border"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_1h"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:text="1 hour"
                        android:fontFamily="@font/inter"
                        app:chipBackgroundColor="@color/color_primary"
                        app:chipStrokeWidth="0dp"
                        android:checked="true" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_2h"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:text="2 hours"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/inter"
                        app:chipBackgroundColor="@color/bg_card_elevated"
                        app:chipStrokeColor="@color/border"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_3h"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:text="3 hours"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/inter"
                        app:chipBackgroundColor="@color/bg_card_elevated"
                        app:chipStrokeColor="@color/border"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_4h"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:text="4 hours"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/inter"
                        app:chipBackgroundColor="@color/bg_card_elevated"
                        app:chipStrokeColor="@color/border"
                        app:chipStrokeWidth="1dp" />

                    <com.google.android.material.chip.Chip
                        android:id="@+id/chip_5h"
                        style="@style/Widget.Material3.Chip.Filter"
                        android:layout_width="wrap_content"
                        android:layout_height="@dimen/chip_height"
                        android:text="5 hours"
                        android:textColor="@color/text_secondary"
                        android:fontFamily="@font/inter"
                        app:chipBackgroundColor="@color/bg_card_elevated"
                        app:chipStrokeColor="@color/border"
                        app:chipStrokeWidth="1dp" />
                </com.google.android.material.chip.ChipGroup>

                <!-- Live limit preview label -->
                <TextView
                    android:id="@+id/tv_current_limit"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="@dimen/space_24"
                    android:textSize="14sp"
                    android:textColor="@color/color_primary"
                    android:fontFamily="@font/inter"
                    android:gravity="center"
                    tools:text="Daily limit: 1 hour" />

                <!-- Save button -->
                <Button
                    android:id="@+id/btn_save"
                    style="@style/Widget.ScrollGuard.Button.Primary"
                    android:layout_width="match_parent"
                    android:layout_height="50dp"
                    android:text="@string/btn_save_limit" />
            </LinearLayout>
        </androidx.core.widget.NestedScrollView>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>
