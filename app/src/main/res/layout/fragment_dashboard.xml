<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <!-- App Bar -->
    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Dashboard"
            app:titleCentered="true"
            app:titleTextAppearance="@style/TextAppearance.ScrollGuard.Headline" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:paddingBottom="80dp"
        app:layout_constraintTop_toBottomOf="@id/appBar"
        app:layout_constraintBottom_toBottomOf="parent">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="20dp">

            <!-- Circular Progress & Daily Stats -->
            <com.google.android.material.card.MaterialCardView
                style="@style/Widget.ScrollGuard.Card"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardBackgroundColor="@color/bg_card_hero"
                app:strokeColor="@color/purple_20">

                <androidx.constraintlayout.widget.ConstraintLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:padding="24dp">

                    <com.google.android.material.progressindicator.CircularProgressIndicator
                        android:id="@+id/progressDaily"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        app:indicatorColor="@color/color_cyan"
                        app:indicatorSize="160dp"
                        app:trackColor="@color/cyan_10"
                        app:trackThickness="12dp"
                        app:layout_constraintTop_toTopOf="parent"
                        app:layout_constraintStart_toStartOf="parent"
                        app:layout_constraintEnd_toEndOf="parent"
                        tools:progress="65"/>

                    <TextView
                        android:id="@+id/tvDailyUsage"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="4h 12m"
                        android:textAppearance="@style/TextAppearance.ScrollGuard.Display"
                        android:textColor="@color/text_primary"
                        app:layout_constraintBottom_toTopOf="@id/tvUsageLabel"
                        app:layout_constraintEnd_toEndOf="@id/progressDaily"
                        app:layout_constraintStart_toStartOf="@id/progressDaily"
                        app:layout_constraintTop_toTopOf="@id/progressDaily"
                        app:layout_constraintVertical_chainStyle="packed" />

                    <TextView
                        android:id="@+id/tvUsageLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Screen Time Today"
                        android:textAppearance="@style/TextAppearance.ScrollGuard.Label"
                        app:layout_constraintBottom_toBottomOf="@id/progressDaily"
                        app:layout_constraintEnd_toEndOf="@id/progressDaily"
                        app:layout_constraintStart_toStartOf="@id/progressDaily"
                        app:layout_constraintTop_toBottomOf="@id/tvDailyUsage" />

                </androidx.constraintlayout.widget.ConstraintLayout>
            </com.google.android.material.card.MaterialCardView>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monitored Apps"
                android:layout_marginBottom="12dp"
                android:textAppearance="@style/TextAppearance.ScrollGuard.Title" />

            <!-- RecyclerView for Monitored Apps -->
            <androidx.recyclerview.widget.RecyclerView
                android:id="@+id/rvMonitoredApps"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:nestedScrollingEnabled="false"
                tools:itemCount="3"
                tools:listitem="@layout/item_monitored_app" />

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <com.google.android.material.floatingactionbutton.ExtendedFloatingActionButton
        android:id="@+id/fabAddApp"
        style="@style/Widget.ScrollGuard.FAB"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_margin="24dp"
        android:text="Add App"
        app:icon="@drawable/ic_add"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>
