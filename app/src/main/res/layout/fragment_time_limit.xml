<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:colorBackground">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/appBar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@android:color/transparent"
        app:elevation="0dp"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Set Time Limit"
            app:titleCentered="true"
            app:titleTextAppearance="@style/TextAppearance.ScrollGuard.Headline"
            app:navigationIcon="@drawable/ic_back" />
    </com.google.android.material.appbar.AppBarLayout>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:orientation="vertical"
        android:padding="24dp"
        app:layout_constraintTop_toBottomOf="@id/appBar"
        app:layout_constraintBottom_toTopOf="@id/bottomAction">

        <!-- App Context -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:orientation="vertical"
            android:layout_marginBottom="32dp">

            <ImageView
                android:id="@+id/ivAppIcon"
                android:layout_width="80dp"
                android:layout_height="80dp"
                android:src="@drawable/ic_shield"
                android:background="@drawable/bg_circle_purple"
                android:padding="16dp"
                app:tint="@color/text_primary" />

            <TextView
                android:id="@+id/tvAppName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:text="Instagram"
                android:textAppearance="@style/TextAppearance.ScrollGuard.Title" />
        </LinearLayout>

        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Daily Allowance"
            android:layout_marginBottom="16dp"
            android:textAppearance="@style/TextAppearance.ScrollGuard.Label" />

        <!-- Number Pickers or Custom Input -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center"
            android:layout_marginBottom="32dp">

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:layout_marginEnd="16dp"
                app:boxStrokeColor="@color/color_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etHours"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Hrs"
                    android:inputType="number"
                    android:textAlignment="center"
                    android:text="1"
                    android:textSize="24sp" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text=":"
                android:textSize="32sp"
                android:layout_marginEnd="16dp"
                android:textColor="@color/text_primary" />

            <com.google.android.material.textfield.TextInputLayout
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                app:boxStrokeColor="@color/color_primary">

                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etMinutes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:hint="Mins"
                    android:inputType="number"
                    android:textAlignment="center"
                    android:text="30"
                    android:textSize="24sp" />
            </com.google.android.material.textfield.TextInputLayout>

        </LinearLayout>

        <!-- Pre-set suggestions -->
        <com.google.android.material.chip.ChipGroup
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:singleSelection="true">

            <com.google.android.material.chip.Chip
                style="@style/Widget.ScrollGuard.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="15m" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.ScrollGuard.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="30m" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.ScrollGuard.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1h" />

            <com.google.android.material.chip.Chip
                style="@style/Widget.ScrollGuard.Chip"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2h" />
        </com.google.android.material.chip.ChipGroup>

    </LinearLayout>

    <androidx.constraintlayout.widget.ConstraintLayout
        android:id="@+id/bottomAction"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@color/bg_primary"
        android:padding="24dp"
        app:layout_constraintBottom_toBottomOf="parent">

        <com.google.android.material.button.MaterialButton
            android:id="@+id/btnSaveLimit"
            style="@style/Widget.ScrollGuard.Button.Primary"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Save Limit"
            app:layout_constraintBottom_toBottomOf="parent" />
    </androidx.constraintlayout.widget.ConstraintLayout>

</androidx.constraintlayout.widget.ConstraintLayout>
